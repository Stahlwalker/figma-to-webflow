# Figma OAuth (register at https://www.figma.com/developers/apps)
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# Webflow OAuth (register at https://developers.webflow.com)
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=

# Session encryption key — generate with: openssl rand -hex 32
SESSION_SECRET=

# Your app's public URL (use ngrok URL in development)
NEXT_PUBLIC_APP_URL=https://localhost:3000

# Designer extension origin for CORS (e.g. https://designer-extension.webflow.io)
DESIGNER_EXTENSION_ORIGIN=*
